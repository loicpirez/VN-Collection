# dependencies
node_modules/

# next.js
.next/
out/
next-env.d.ts
*.tsbuildinfo

# secrets — never commit
.env
.env.local
.env.*.local

# user-local data
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm
data/storage/
# legacy / archive copies of user data — never sync to source control
data.old/
data.old.*/
data.*.bak/

# os
.DS_Store
Thumbs.db

# logs / temp
*.log
/tmp/
# Round-N verification logs (kept locally, not source-controlled).
logs/
# Isolated QA tree used by scripts/browser-qa.sh + the QA dev
# server. Holds a copy of the real DB + a throwaway storage tree
# so write-capable QA does not touch the user's data.
.qa/

# editor
.vscode/
.idea/
*.swp
vndb-colection-data.zip
.claude/
